# --- REQUIRED ---
# Cookie header value used to authenticate to https://api.rpow3.com.
#
# Easiest way to get this: run the built-in login subcommand
#
#   rpow-miner login --email YOUR_EMAIL
#
# It will email you a magic link, you paste the link back, and it prints the
# RPOW_COOKIE value for you. The same flow doubles as account registration
# — first magic-link verification creates the account on the server.
#
# Manual fallback: log in at https://rpow3.com, open DevTools -> Application
# -> Cookies -> https://api.rpow3.com, and copy the value of the cookie
# named `rpow_session`. Then set:
#   RPOW_COOKIE="rpow_session=<the_value>"
RPOW_COOKIE="rpow_session=PASTE_YOUR_SESSION_TOKEN_HERE"

# --- OPTIONAL ---
# Number of CPU cores to use. Defaults to all logical CPUs.
# RPOW_THREADS=4

# API base URL. Defaults to https://api.rpow3.com (no need to change).
# RPOW_API_BASE=https://api.rpow3.com

# Origin header sent to the API. Defaults to https://rpow3.com.
# RPOW_ORIGIN=https://rpow3.com

# tracing log level (off, error, warn, info, debug, trace). Default: info.
# RPOW_LOG=info

# Status HTTP port. Railway injects $PORT automatically; only override if you
# self-host. Default: $PORT or 8080.
# RPOW_STATUS_PORT=8080
# RPOW_STATUS_DISABLED=0

# --- LEGACY ALIASES ---
# All of the above also accept the old RPOW2_* names that targeted rpow2.com,
# so existing deployments keep working without changes:
#   RPOW2_COOKIE, RPOW2_API_BASE, RPOW2_ORIGIN, RPOW2_THREADS, RPOW2_LOG,
#   RPOW2_STATUS_PORT, RPOW2_STATUS_DISABLED
